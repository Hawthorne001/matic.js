{
  "name": "@maticnetwork/maticjs",
  "version": "3.9.7",
  "description": "Javascript developer library for interacting with Matic Network",
  "main": "dist/npm.export.js",
  "types": "dist/ts/index.d.ts",
  "browser": "dist/matic.umd.js",
  "react-native": "dist/matic.node.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xPolygon/matic.js.git",
    "directory": "packages/maticjs"
  },
  "files": [
    "dist",
    "MIGRATION.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build:dev": "webpack",
    "build:prod": "webpack --env build",
    "build": "pnpm run clean && pnpm run build:dev && pnpm run build:prod",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ethereum",
