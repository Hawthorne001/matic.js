{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "erasableSyntaxOnly": false,
    "verbatimModuleSyntax": false,
    "lib": ["es2015", "dom"],
    "target": "ES2015",
    "moduleResolution": "node",
    "declaration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist/ts",
    "rootDir": "src"
  },
  "include": ["src/**/*"]
}
