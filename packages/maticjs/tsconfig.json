{
  "compilerOptions": {
    "noEmit": true,
    "erasableSyntaxOnly": false,
    "verbatimModuleSyntax": false,
    "lib": ["es2015", "dom"],
    "target": "ES2015",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "tests/**/*", "vitest.config.ts"]
}
